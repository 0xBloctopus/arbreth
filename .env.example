# Ethereum Sepolia L1 RPC URL (Alchemy, Infura, etc.)
PARENT_CHAIN_RPC_URL=<ethereum-sepolia-rpc>

# Ethereum Sepolia Beacon API URL
PARENT_CHAIN_BEACON_URL=<ethereum-sepolia-beacon>

# Arbitrum chain ID (421614 = Sepolia, 42161 = One)
CHAIN_ID=421614

# Nitro log level (TRACE, DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
